# 邮件配置文件模板
# 复制此文件为 email_config.yaml 并填写实际配置

recipients:
  - your_email@example.com

# 发件人配置 (QQ邮箱SMTP)
sender: your_qq@qq.com
smtp_server: smtp.qq.com
smtp_port: 587
smtp_password: your_smtp_authorization_code  # QQ邮箱授权码，非密码

# 邮件设置
settings:
  region: cn-hangzhou
  address_type: 1  # 1 表示互联网邮箱
  reply_to: true

# 注意：
# 1. QQ邮箱授权码获取：登录QQ邮箱 -> 设置 -> 账户 -> POP3/SMTP服务 -> 生成授权码
# 2. 此文件包含敏感信息，已添加到 .gitignore