# LLM Provider Configuration
# Choose provider: "qwen" or "azure"
LLM_PROVIDER=qwen

# Qwen API Configuration
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_MODEL=qwen-flash-2025-07-28

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Email Configuration (Optional - for paper search results)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here
RECEIVER_EMAIL=receiver@example.com

# Brave Search API (for weekly keyword discovery)
BRAVE_API_KEY=your_brave_api_key_here

# SMTP Email Configuration (for sending reports)
SMTP_PASSWORD=your_smtp_authorization_code

# Feature Flags
# Enable topic-based report (true) or paper-by-paper report (false)
TOPIC_BASED_REPORT=true
# Enable history deduplication
ENABLE_HISTORY_DEDUP=false

# Polygon.io API (Required for stock data when Yahoo is rate limited)
# Free tier: 5 requests/minute, 1 request/sec, 2 years full historical data
# Get free key at: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Alpha Vantage API (Alternative)
# Note: Full historical data requires premium now
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Finnhub API (Alternative - free tier doesn't include full history)
# FINNHUB_API_KEY=your_finnhub_api_key_here
